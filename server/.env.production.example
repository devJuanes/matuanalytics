NODE_ENV=production
PORT=3001

# URLs públicas
API_URL=https://api.matubyte.com
CORS_ORIGIN=https://matuanalytics.matubyte.com

# Seguridad — generar un secreto fuerte en el servidor
JWT_SECRET=CAMBIAR_POR_SECRETO_LARGO_ALEATORIO

# Firebase Realtime Database
FIREBASE_DATABASE_URL=https://matuanalytics-37f2f-default-rtdb.firebaseio.com
# Ruta absoluta en el servidor Linux
FIREBASE_SERVICE_ACCOUNT_PATH=/var/www/matuanalytics/serviceAccountKey.json

# Datos locales (fallback si RTDB no está disponible)
DATA_DIR=/var/www/matuanalytics/server/data

TRACKER_URL=https://matuanalytics.matubyte.com
